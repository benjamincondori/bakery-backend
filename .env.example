# Application
NODE_ENV=development
PORT=3000
APP_NAME=BakeryManagement
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://bakery:bakery_secret@localhost:5432/bakery_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug
